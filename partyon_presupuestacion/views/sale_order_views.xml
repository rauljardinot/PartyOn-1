<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_partyon_estimate" model="ir.ui.view">
        <field name="name">sale.order.form.partyon.estimate</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//div[@name='button_box']" position="inside">
                <button name="action_view_partyon_estimate" type="object" class="oe_stat_button" icon="fa-calculator" invisible="not partyon_estimate_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Estimate</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//sheet//group" position="inside">
                <field name="partyon_estimate_id" readonly="1" invisible="not partyon_estimate_id"/>
            </xpath>
        </field>
    </record>
</odoo>
